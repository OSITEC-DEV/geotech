<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Lims Batch Number -->
        <record id="seq_lims_batch" model="ir.sequence">
            <field name="name">LIMS Batch Number</field>
            <field name="code">lims.batch</field>
            <field name="prefix">BATCH/</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="number_next_actual">1</field>
        </record>


        <record forcecreate="True" id="decimal_batch_cost_uom" model="decimal.precision">
            <field name="name">Batch cost</field>
            <field name="digits" eval="3"/>
        </record>


        <record id="picking_type_consumption" model="stock.picking.type">
            <field name="name">Consumption</field>
            <field name="code">internal</field> <!-- Internal movement type -->
            <field name="sequence_code">CONS</field>
            <field name="warehouse_id" ref="stock.warehouse0"/> <!-- Refers to the main warehouse -->
            <field name="default_location_src_id" ref="stock.stock_location_stock"/> <!-- Stock location as source -->
            <field name="default_location_dest_id" ref="stock.stock_location_output"/> <!-- Output location as destination -->
        </record>
    </data>

</odoo>