<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<!-- ═══════════════════════════════════════════════════════════════════════════
     REPORT SPEC FIX DIALOG
     3-mode dialog: Switch existing limit | Edit values | Create new
════════════════════════════════════════════════════════════════════════════ -->
<t t-name="lims_report.ReportSpecFixDialog">
    <Dialog title="'Fix Limit &amp; Specification'" size="'lg'">

        <!-- Loading spinner -->
        <t t-if="state.loading">
            <div class="d-flex justify-content-center align-items-center p-5">
                <div class="spinner-border text-primary" role="status"/>
            </div>
        </t>

        <t t-else="">
            <!-- ── Context bar ─────────────────────────────────────────── -->
            <div class="alert alert-light py-2 mb-3 d-flex align-items-center gap-2" style="font-size:0.85rem">
                <i class="fa fa-flask text-primary"/>
                <span><strong>Analyte:</strong> <t t-esc="state.analyteName"/></span>
            </div>

            <!-- ── Mode tabs ──────────────────────────────────────────── -->
            <ul class="nav nav-pills nav-fill mb-3">
                <li class="nav-item" t-if="state.availableLimits.length">
                    <a class="nav-link" t-att-class="{'active': state.tab === 'switch'}"
                       t-on-click="() => setTab('switch')" href="#" t-on-click.prevent="">
                        <i class="fa fa-exchange me-1"/>Switch Limit
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" t-att-class="{'active': state.tab === 'edit'}"
                       t-on-click="() => setTab('edit')" href="#" t-on-click.prevent="">
                        <i class="fa fa-pencil me-1"/>Edit Values
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" t-att-class="{'active': state.tab === 'create'}"
                       t-on-click="() => setTab('create')" href="#" t-on-click.prevent="">
                        <i class="fa fa-plus me-1"/>Create New
                    </a>
                </li>
            </ul>

            <!-- ── SWITCH TAB ─────────────────────────────────────────── -->
            <t t-if="state.tab === 'switch'">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Select Existing Limit</label>
                    <select class="form-select" t-on-change="onSwitchLimitChange">
                        <t t-foreach="state.availableLimits" t-as="l" t-key="l.id">
                            <option t-att-value="l.id"
                                    t-att-selected="state.switchToId === l.id">
                                <t t-esc="l.name"/>
                                <t t-if="l.regulation_name"> — <t t-esc="l.regulation_name"/></t>
                            </option>
                        </t>
                    </select>
                    <div class="form-text text-muted mt-1">
                        Switching will recompute the specification from the selected limit's values.
                    </div>
                </div>

                <!-- Preview the selected limit's values -->
                <t t-set="sel" t-value="state.availableLimits.find(l => l.id === state.switchToId)"/>
                <t t-if="sel">
                    <div class="card bg-light border-0 p-3 mb-2" style="font-size:0.85rem">
                        <div class="row g-2">
                            <div class="col-4"><span class="text-muted">Type:</span> <strong><t t-esc="sel.limit_type.toUpperCase()"/></strong></div>
                            <div class="col-4" t-if="sel.mrl"><span class="text-muted">MRL:</span> <t t-esc="sel.mrl"/></div>
                            <div class="col-4" t-if="sel.max_value"><span class="text-muted">Max:</span> <t t-esc="sel.max_value"/></div>
                            <div class="col-4" t-if="sel.min_value"><span class="text-muted">Min:</span> <t t-esc="sel.min_value"/></div>
                            <div class="col-4" t-if="sel.lod"><span class="text-muted">LOD:</span> <t t-esc="sel.lod"/></div>
                            <div class="col-4" t-if="sel.loq"><span class="text-muted">LOQ:</span> <t t-esc="sel.loq"/></div>
                            <div class="col-12" t-if="sel.regulation_name"><span class="text-muted">Regulation:</span> <t t-esc="sel.regulation_name"/></div>
                        </div>
                    </div>
                </t>
            </t>

            <!-- ── EDIT / CREATE TABS (shared values form) ────────────── -->
            <t t-if="state.tab === 'edit' or state.tab === 'create'">

                <!-- Auto-filled context info shown only on Create tab -->
                <t t-if="state.tab === 'create'">
                    <div class="alert alert-info py-2 mb-3 d-flex gap-3" style="font-size:0.82rem">
                        <div t-if="state.instrumentName">
                            <i class="fa fa-cogs me-1 text-info"/>
                            <strong>Instrument:</strong> <t t-esc="state.instrumentName"/>
                        </div>
                        <div t-if="state.sampleCategoryName">
                            <i class="fa fa-tag me-1 text-info"/>
                            <strong>Category:</strong> <t t-esc="state.sampleCategoryName"/>
                        </div>
                        <div t-if="state.sampleTypeName">
                            <i class="fa fa-flask me-1 text-info"/>
                            <strong>Sample Type:</strong> <t t-esc="state.sampleTypeName"/>
                        </div>
                        <div class="text-muted ms-auto" style="font-size:0.78rem;align-self:center">
                            Auto-filled from this analysis
                        </div>
                    </div>
                </t>

                <!-- Limit type -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Limit Type</label>
                    <select class="form-select" t-on-change="onLimitTypeChange">
                        <option value="mrl"   t-att-selected="state.limitType === 'mrl'">MRL — Maximum Residue Limit</option>
                        <option value="max"   t-att-selected="state.limitType === 'max'">Maximum Value</option>
                        <option value="range" t-att-selected="state.limitType === 'range'">Min / Max Range</option>
                    </select>
                </div>

                <hr class="my-3"/>

                <!-- MRL -->
                <t t-if="state.limitType === 'mrl'">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">MRL Value</label>
                        <div class="input-group">
                            <span class="input-group-text">≤</span>
                            <input type="number" step="0.0001" min="0" class="form-control"
                                   t-att-value="state.mrl"
                                   t-on-input="onMrlInput"
                                   placeholder="0.0000"/>
                        </div>
                    </div>
                </t>

                <!-- Range -->
                <t t-if="state.limitType === 'range'">
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold">Minimum Value</label>
                            <div class="input-group">
                                <span class="input-group-text">≥</span>
                                <input type="number" step="0.0001" min="0" class="form-control"
                                       t-att-value="state.minValue"
                                       t-on-input="onMinInput"
                                       placeholder="0.0000"/>
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold">Maximum Value</label>
                            <div class="input-group">
                                <span class="input-group-text">≤</span>
                                <input type="number" step="0.0001" min="0" class="form-control"
                                       t-att-value="state.maxValue"
                                       t-on-input="onMaxInput"
                                       placeholder="0.0000"/>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- Max only -->
                <t t-if="state.limitType === 'max'">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Maximum Value</label>
                        <div class="input-group">
                            <span class="input-group-text">≤</span>
                            <input type="number" step="0.0001" min="0" class="form-control"
                                   t-att-value="state.maxValue"
                                   t-on-input="onMaxInput"
                                   placeholder="0.0000"/>
                        </div>
                    </div>
                </t>

                <!-- UoM + Regulation -->
                <div class="row g-3 mb-1">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Unit (UoM)</label>
                        <select class="form-select" t-on-change="onUomChange">
                            <option value="">— None —</option>
                            <t t-foreach="state.uoms" t-as="uom" t-key="uom.id">
                                <option t-att-value="uom.id"
                                        t-att-selected="state.uomId === uom.id">
                                    <t t-esc="uom.name"/>
                                </option>
                            </t>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Regulation</label>
                        <select class="form-select" t-on-change="onRegulationChange">
                            <option value="">— None —</option>
                            <t t-foreach="state.regulations" t-as="reg" t-key="reg.id">
                                <option t-att-value="reg.id"
                                        t-att-selected="state.regulationId === reg.id">
                                    <t t-esc="reg.name"/>
                                </option>
                            </t>
                        </select>
                    </div>
                </div>
            </t>

            <!-- ── SPECIFICATION SECTION (always visible) ─────────────── -->
            <hr class="my-3"/>
            <div class="p-3 rounded-2" style="background:var(--bs-light, #f8f9fa)">
                <div class="fw-semibold mb-2 text-muted" style="font-size:0.8rem;letter-spacing:.05em;text-transform:uppercase">
                    Specification Preview
                </div>
                <!-- Live preview badge -->
                <div class="mb-3">
                    <span class="badge fs-6 py-2 px-3"
                          t-att-class="specPreview !== '—' ? 'bg-primary text-white' : 'bg-secondary text-white'">
                        <t t-esc="specPreview"/>
                    </span>
                    <div class="form-text mt-1">
                        Auto-computed from the values above. You can override it below.
                    </div>
                </div>
                <!-- Manual override -->
                <div>
                    <label class="form-label fw-semibold" style="font-size:0.85rem">Override Specification</label>
                    <input type="text" class="form-control form-control-sm"
                           t-att-value="state.specificationOverride"
                           t-on-input="onSpecInput"
                           placeholder="Leave blank to use auto-computed value above"/>
                </div>
            </div>

        </t><!-- end t-else (not loading) -->

        <footer>
            <button class="btn btn-primary" t-att-disabled="state.saving or state.loading"
                    t-on-click="onSaveClick">
                <t t-if="state.saving"><span class="spinner-border spinner-border-sm me-1"/>Saving…</t>
                <t t-else="">Save</t>
            </button>
            <button class="btn btn-secondary ms-2" t-on-click="onCancelClick">Cancel</button>
        </footer>

    </Dialog>
</t>

<!-- ═══════════════════════════════════════════════════════════════════════════
     REPORT SPEC WIDGET — inline field in the analysis list
════════════════════════════════════════════════════════════════════════════ -->
<t t-name="lims_report.ReportSpecWidget">
    <div class="d-flex align-items-center gap-2 w-100" t-on-click.stop=""  t-on-mousedown.stop="">

        <!-- Limit badge -->
        <t t-if="limitName">
            <span class="badge bg-info text-white text-truncate" style="max-width:120px;font-size:0.7rem"
                  t-att-title="limitName">
                <t t-esc="limitName"/>
            </span>
        </t>
        <t t-else="">
            <span class="badge bg-warning text-dark" style="font-size:0.7rem">No limit</span>
        </t>

        <!-- Specification — click opens dialog (inline edit not possible in readonly list) -->
        <span class="flex-grow-1 text-truncate"
              t-att-class="{'text-muted fst-italic': !displaySpec}"
              t-att-title="displaySpec"
              t-on-click="openDialog"
              style="cursor:pointer; min-width:60px">
            <t t-if="displaySpec"><t t-esc="displaySpec"/></t>
            <t t-else="">—</t>
        </span>

        <!-- Fix dialog button — always shown; server rejects saves on validated reports -->
        <button class="btn btn-sm btn-link p-0 text-primary flex-shrink-0"
                title="Fix Limit &amp; Specification"
                t-on-click="openDialog"
                style="line-height:1">
            <i class="fa fa-sliders"/>
        </button>

        <!-- Saving spinner -->
        <t t-if="state.saving">
            <span class="spinner-border spinner-border-sm text-secondary flex-shrink-0"/>
        </t>

    </div>
</t>

</templates>
