<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="product_template_form_view_inherit2" model="ir.ui.view">
        <field name="name">product.template.form.inherit2</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="lims.product_template_form_view_inherit2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='nb_decimal']" position="after">
                <field name='parameter_print_id' style='width:auto;'
                       required=" isParameter == True"/>
            </xpath>
        </field>
    </record>


    <record id="reports_action" model="ir.actions.act_window">
        <field name="name">Reports</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">lims.report</field>
        <field name="view_mode">list,form,search</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <record id="print_group_action" model="ir.actions.act_window">
        <field name="name">Print Group</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">lims.parameter.print.group</field>
        <field name="view_mode">list,form,search</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>


    <menuitem id="menu_lims_report_root" name="Reports" parent="lims.menu_lims_root" sequence="1"/>
    <menuitem id="menu_customers" name="Reports" action="reports_action"
              parent="menu_lims_report_root" sequence="1"/>

    <menuitem id="menu_reports_root" name="Reports" action="reports_action"
              web_icon="lims_report,static/description/icon.png"
              sequence="1"/>

    <menuitem id="menu_reports" name="Reports" action="reports_action"
              parent="menu_reports_root" sequence="1"/>


    <menuitem id="menu_print_group" name="Print Group" action="print_group_action"
              parent="lims.menu_lims_config_report" sequence="3"/>

</odoo>