<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="lims_report_spec_fix_wizard_form" model="ir.ui.view">
            <field name="name">lims.report.spec.fix.wizard.form</field>
            <field name="model">lims.report.spec.fix.wizard</field>
            <field name="arch" type="xml">
                <form string="Fix Limit &amp; Specification">
                    <sheet>
                        <group string="Analyte">
                            <field name="analyte_name" readonly="1"/>
                            <field name="product_id" invisible="1"/>
                            <field name="analysis_id" invisible="1"/>
                            <field name="current_specification" readonly="1"/>
                        </group>
                        <group string="Correction">
                            <field name="limit_id"
                                   options="{'no_create': True}"
                                   help="Pick the correct limit — specification will be recomputed automatically on save."/>
                            <field name="specification"
                                   placeholder="Leave blank to auto-compute from limit above"
                                   help="Optional manual override. Only needed if no matching limit record exists."/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_apply"
                                string="Apply"
                                type="object"
                                class="btn-primary"
                                data-hotkey="q"/>
                        <button string="Cancel"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
