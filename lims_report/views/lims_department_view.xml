<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="lims_department_view_inherit_form" model="ir.ui.view">
            <field name="name">lims.department.main.form.inherit</field>
            <field name="model">lims.department</field>
            <field name="priority" eval="15"/>
            <field name="inherit_id" ref="lims.lims_department_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <group string="Reports">
                        <field name="default_hide_table"/>
                        <field name="subcontracting_note"/>
                        <field name="auto_validate_report"/>
                        <field name="text_in_report"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
