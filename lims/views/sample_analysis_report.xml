                                                               <img t-if="o.qr_code" t-att-src="image_data_uri(o.qr_code)" style="height: 150px;" alt="QR Code"/>
                                                           </div>
                                                       </div> -->
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <report
                id="medical_lab_sample_analysis_report"
                model="lims.sample.preparation"
                report_type="qweb-pdf"
                string="Analysis Report"
                name="lims.sample_analysis_report_document"
                file="lims.sample_analysis_report"
                print_report_name="'Report - %s' % (object.partner_id.name or '',)"
                paperformat="lims.paperformat_medical_lab_report"
        />

    </data>
</odoo>