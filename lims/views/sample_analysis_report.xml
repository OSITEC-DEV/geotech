                                                            <div class="row">
                                                                <div class="col-6">
                                                                    <div style="width:90%" class="text-center">
                                                                        <div class="logo">
                                                                            <img src="/medical_lab/static/img/ministry_of_Health_Logo.png" style="width: 110px;" alt="Logo"/>
                                                                        </div>
                                                                        <div>
                                                                            <p>أحد المؤسسات المرخصة من وزارة الصحة السعودية</p>
                                                                            <p>Accredited by saudi Ministry of Health</p>
                                                                        </div>
                                                                    </div>

                                                                </div>
                                                                <div class="col-6">
                                                                    <p style="text-align:left">مختبر شركة آجال السعودية</p>
                                                                    <div style="text-align: center;">
                                                                        <img src="/medical_lab/static/img/seal.png" style="width:210px;" alt="Seal"/>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                       </div> -->
                            <br/>
                            <br/>
                            <!--                            <div class="barcode">
                                                           <div class="row">
                                                               <div class="col-6" style="text-align:right;">قم بمسح الباركود للتحقق من التقرير الكترونيا</div>
                                                               <div class="col-6" style="text-align:left;">Scan the QR code to electronically check the report</div>
                                                           </div>
                                                           <br/>
