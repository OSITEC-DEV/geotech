<!--                </div>-->
<!--            </div>-->

<!--        </xpath>-->
    </template>


    <template id="report_saleorder">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="lims.report_saleorder_doc" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>


</odoo>
