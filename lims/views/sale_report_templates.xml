<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_saleorder_doc" inherit_id="sale.report_saleorder_document">
        <xpath expr="//p[@t-if='doc.partner_id.vat']" position="replace">
            <p t-if="doc.partner_id.partner_no">Customer ID :
                <span t-field="doc.partner_id.partner_no"/>
            </p>
        </xpath>
        <xpath expr="//div[@id='informations']" position="inside">
            <div t-if="doc.commitment_date and doc.state not in ['draft','sent']" class="col-auto col-3 mw-100 mb-2">
                <strong>Estimated Date Send:</strong>
                <p class="m-0" t-field="doc.commitment_date"/>
            </div>
        </xpath>
