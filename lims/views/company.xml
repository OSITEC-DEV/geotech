<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_company_form_view_inherit_lims" model="ir.ui.view">
        <field name="name">res.company.inherit</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_info']" position="after">

                <page string='Lims'>
                    <group string="LIMS Sequences">
                        <field name="sequence_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="name"/>
                                <field name="code"/>
                                <field name="prefix"/>
                                <field name="padding"/>
                                <field name="number_next"/>
                            </list>
                        </field>
                        <group string="Logo" col='4'>
                            <field name='logo_gov' widget='image' style="" class="oe_avatar"
                                   help='Add signature of government to the report result'/>
                            <field name='logo_quality' class="oe_avatar" widget='image'
                                   help='Add Quality Logo to the report result'/>
                            <field name='logo_iso' class="oe_avatar" widget='image'
                                   help='Add iso logo to the report result'/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>