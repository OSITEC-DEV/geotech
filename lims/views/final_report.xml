                            <style>
                                table.print-friendly tr td , table-print-friendly tr th {
                                page-break-inside: avoid !important;
                                }
                            </style>
                            <div>
                                <table class="table table-sm o_main_table"
                                       style="width: 100%;font-size:14px;">
                                    <!-- In case we want to repeat the header, remove "display: table-row-group" -->
                                    <t t-set="sample_id" t-value=""/>
                                    <t t-set='test_no' t-value='1'/>
                                    <t t-set='iter' t-value='0'/>
                                    <tbody>
                                        <tr id="analysis"
                                            t-foreach="o.analysis_ids.filtered(lambda a:a.state == 'valid').sorted(key=lambda x:(x.sample_line_id.id,x.pack_selected.id,x.method_id.id))"
                                            t-as="a" name="analysis_info">
                                            <t t-if="sample_id !=a.sample_line_id.id">
                                                <t t-set='iter' t-value='iter+1'/>
                                                <t t-set='test_no' t-value='1'/>
                                                <t t-set="sample_id" t-value="a.sample_line_id.id"/>
                                                <tr>
                                                    <td colspan="5" style="border:none;border-top: none;">
                                                        <br/>
                                                        <!--you just need a space in a row-->
                                                    </td>
                                                </tr>
                                                <tr name="th_table">
                                                    <th class="text-left" colspan="2">
                                                        <strong><span t-esc="iter"/>- Sample specimen type :
                                                        </strong>
                                                        <span t-field="a.sample_line_id.sample"
                                                              style="font-weight:normal;"/>

                                                    </th>
                                                    <th class="text-left">
                                                        <div/>
                                                    </th>
                                                    <th class="text-left" colspan="2">
                                                        <strong>Source:</strong>
                                                        <span t-field="a.main_id.origin" t-if="a.main_id.origin"
                                                              style="font-weight:normal;"/>

                                                    </th>
                                                    <th class="text-left">
                                                        <span/>
                                                    </th>
                                                </tr>
                                                <tr name="th_table">
                                                    <th name="th_sample_date" class="text-left" colspan="2">
                                                        <strong>Registered:</strong>
                                                        <span t-field="a.sample_line_id.date"
                                                              t-options='{"format": "dd/MM/yyyy H:mm"}'/>
                                                    </th>
                                                    <th name="th_sample_date" class="text-left">
                                                        <strong>Collected:</strong>
                                                        <span t-field="a.sample_line_id.sample_date"
                                                              t-options='{"format": "dd/MM/yyyy H:mm"}'/>
                                                    </th>
                                                    <th name="th_sample_date" class="text-left" colspan="2">
                                                        <strong>Received:</strong>
                                                        <span t-field="a.sample_line_id.receiving_date"
                                                              t-options='{"format": "dd/MM/yyyy H:mm"}'/>
                                                    </th>
                                                </tr>

                                                <tr name="th_table"
                                                    t-if="not o.hide_table_result">

                                                    <th name="th_description" class="text-left"
                                                        style="color:#576eaf;">
                                                        Test
                                                    </th>
                                                    <th name="th_quantity" class="text-left"
                                                        style="color:#576eaf;">
                                                        Result
                                                    </th>
                                                    <th name="th_priceunit" class="text-left" colspan="2"
                                                        style="color:#576eaf;">
                                                        Range
                                                    </th>
                                                    <t t-if="o.print_method">
                                                        <th name="th_priceunit" class="text-left"
                                                            style="color:#576eaf;">
                                                            Method
                                                        </th>
                                                    </t>
                                                    <t t-if="not o.print_method">
                                                        <th name="th_priceunit" class="text-left"
                                                            style="visibility: hidden;color:#f8a464;">
                                                        </th>
                                                        <span/>
                                                    </t>
                                                </tr>
                                            </t>
                                            <tr
                                                    t-if="not o.hide_table_result and a.parameter_print_id.print_name">
                                                <t t-if="a.state_result not in ('oor','hight','low')">
                                                    <td name="td_result_name" class="text-left">
                                                        <span style="color:#576eaf;">
                                                            <span t-esc="test_no"
                                                                  t-options="{'widget': 'text'}"/>
                                                            |
                                                        </span>

                                                        <span t-if="a.parameter_print_id"
                                                              t-field="a.parameter_print_id.print_name"/>
                                                    </td>

                                                    <td name="td_result" class="text-left table-active">
                                                        <strong>
                                                            <span t-field="a.result_num"
                                                                  t-options='{"precision":a.product_id.nb_decimal}'
                                                                  t-if="a.result_num"/>
                                                        </strong>
                                                        <strong>
                                                            <span t-field="a.result_se" t-if="a.result_se"/>
                                                        </strong>
                                                        <strong>
                                                            <span t-field="a.result_txt"
                                                                  t-if="a.result_txt and a.result_num == 0.0 and not a.result_se"/>
                                                        </strong>
                                                        <span t-field="a.uom_id" style="font-size:10px;"/>
                                                        <i t-if="o.print_old_result">
                                                            <span t-if="a.last_old_result" style="color: red;">Old
                                                                result:
                                                            </span>
                                                            <span t-field="a.last_old_result" t-if="a.last_old_result"/>
                                                        </i>
                                                    </td>
                                                    <td name="td_range" colspan="2" class="text-left">
                                                        <div class='inline-flex' t-raw="a.return_range_txt()"
                                                             style="font-size:12px;"/>
                                                    </td>
                                                    <t t-if="o.print_method">
                                                        <td name="td_method" class="text-left">
                                                            <span t-field="a.method_id"/>
                                                        </td>
                                                    </t>
                                                    <t t-if="not o.print_method">
                                                        <td name="th_priceunit" class="text-left">
                                                        </td>
                                                        <span/>
                                                    </t>
                                                </t>
                                                <t t-else="">
                                                    <td name="td_result_name" class="text-left">
                                                        <span style="color:#576eaf;">
                                                            <span t-esc="test_no"
                                                                  t-options="{'widget': 'text'}"/>
                                                            |
                                                        </span>

                                                        <span t-if="a.parameter_print_id"
                                                              t-field="a.parameter_print_id.print_name"/>
                                                    </td>
                                                    <td name="td_result" class="text-left table-active">
                                                        <strong>
                                                            <span t-field="a.result_num" style="color: red;"
                                                                  t-if="a.result_num"
                                                                  t-options='{"precision":a.product_id.nb_decimal}'/>
                                                            <span t-field="a.result_se" style="color: red;"
                                                                  t-if="a.result_se"/>
                                                            <span t-field="a.result_txt" style="color: red;"
                                                                  t-if="a.result_txt and a.result_num == 0.0 and not a.result_se"/>
                                                        </strong>
                                                        <span t-field="a.uom_id" style="font-size:10px;"
                                                              t-if="a.uom_id"/>
                                                        <span t-if="'hight' in a.state_result" style="color:red;">-High-
                                                        </span>
                                                        <span t-if="'low' in a.state_result" style="color:red;">-Low-
                                                        </span>
                                                        <span t-if="a.last_old_result and o.print_old_result">Old
                                                            result:
                                                        </span>
                                                        <span t-field="a.last_old_result"
                                                              t-if="a.last_old_result and o.print_old_result"
                                                              style="color: red;"/>
                                                    </td>
                                                    <td name="td_range" class="text-left" colspan="2"
                                                        style="font-size:12px;">
                                                        <div class='inline-flex' t-raw="a.return_range_txt()"/>
                                                    </td>
                                                    <t t-if="o.print_method">
                                                        <td name="td_method_abn" class="text-left">
                                                            <span t-field="a.method_id"/>
                                                        </td>
                                                    </t>
                                                    <t t-if="not o.print_method">
                                                        <td name="th_priceunit" class="text-left">
                                                        </td>
                                                        <span/>
                                                    </t>
                                                </t>
                                            </tr>
                                            <t t-set='test_no' t-value='test_no+1'/>
                                        </tr>
                                    </tbody>
                                </table>
                                <t t-foreach="o.analysis_ids.filtered(lambda a:a.state == 'valid').sorted(key=lambda
                                       x:(x.sample_line_id.id,x.pack_selected.id,x.method_id.id))"
                                   t-as="a" name="analysis_info">
                                    <div t-if="a.eng_text != '&lt;p&gt;&lt;br&gt;&lt;/p&gt;' "
                                         style="page-break-inside: auto !important;">
                                        <span t-raw="a.eng_text"/>
                                    </div>
                                </t>
                                <div class="notes" t-if="o.consultant_note">
                                    <span t-raw="o.consultant_note"/>
                                </div>
                                <div
                                        style="display: flex;flex-wrap: wrap;line-height: 1.5;text-align:center;border-spacing: 10px;page-break-inside: avoid;"
                                        class="container">
                                    <div class="row" style="position:center;">
                                        <div class="col" style="width: 70%;">
                                            <t t-set="validators"
                                               t-value="o.analysis_ids.filtered(lambda a:a.validated_by != 'False').mapped('validated_by')"/>
                                            <table class="print-friendly "
                                                   style="font-size:14px;">
                                                <tr style="border: 1pt solid black;" t-foreach="set(validators)"
                                                    t-as="s"
                                                    t-if="validators.mapped('signature_image')">
                                                    <t t-set="a" t-value="1"/>
                                                    <tr t-if="s.signature_image and a == 1">
                                                        <th colspan="3" style="color:#576eaf;">
                                                            <strong class="text-left">Reviewed by</strong>
                                                        </th>
                                                    </tr>
                                                    <tr colspan="99" t-if="s.signature_image">
                                                        <tr width="50%" style="text-align:center;">
                                                            <td>
                                                                <span t-field="s.name"/>
                                                            </td>

                                                        </tr>
                                                        <tr width="50%" style="text-align:center;">
                                                            <td>
                                                                <span t-esc="s.get_job_id()"/>
                                                            </td>

                                                        </tr>
                                                        <tr style="text-align:left;">
                                                            <td style="text-align:left;">
                                                                <img t-att-src="image_data_uri(s.signature_image)"
                                                                     style="max-height: 70px;" alt="Logo"/>
                                                            </td>

                                                        </tr>
                                                    </tr>
                                                    <t t-set="a" t-value="2"/>
                                                </tr>
                                            </table>
                                        </div>
                                        <div name="column" style="width: 30%;" class="text-right"
                                             t-if="o.consultation_date">
                                            <table class="print-friendly"
                                                   style="font-size:14px;text-align:center;">

                                                <tr>
                                                    <th style="color:#576eaf;">Consultant Signature</th>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        <span t-field="o.consultant_id.name"/>
                                                    </td>
                                                </tr>
                                                <tr style="text-align:left;">
                                                    <td style="text-align:left;">
                                                        <img t-att-src="image_data_uri(o.consultant_id.signature_image)"
                                                             style="max-height: 70px;" alt="Logo"/>
                                                    </td>
                                                </tr>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                            </div>
                            <t t-if="o.state not in ['valid','sent']">
                                <center style="font-size:16px;color:red;position:center;">
                                    <p>مسودة تقرير يمنع اعتمادها بصفة رسمية</p>
                                    <p>A draft report , not for official use</p>
                                </center>
                            </t>
                            <t t-if="o.notes">
                                <center style="font-size:14px;color:red;position:center;">
                                    <span t-raw="o.notes"/>
                                </center>
                            </t>
                            <center t-if="o.state in ['valid','sent']">
                                <!--                                <div class="col-4" style="text-align:left;" t-if="o.company_id.logo_iso">-->
                                <!--                                    <img t-att-src="image_data_uri(o.company_id.logo_iso)" style="max-height:70px;"-->
                                <!--                                         alt="Logo"/>-->
                                <!--                                </div>-->
                                <img t-att-src="image_data_uri(res_company.signature_director)"
                                     t-if="res_company.signature_director"
                                     style="max-height: 110px;"
                                     alt="Logo"
                                />
                            </center>

                            <div class="footer" style="border-top: 1px solid grey;font-size:12px;;">
                                <br/>
                                <div class="row d-flex justify-content-center justify-content-center">
                                    <div class="col-6">
                                        <strong>Address:</strong>
                                        <span t-field="res_company.street" t-if="res_company.street"/>,
                                        <span t-field="res_company.state_id" t-if="res_company.state_id"/>,
                                        <span t-field="res_company.country_id" t-if="res_company.country_id"/>

                                        <span style="text-align:center;" t-if="res_company.company_registry">
                                            <strong>CR:</strong>
                                            <span t-field="res_company.company_registry"/>
                                        </span>
                                    </div>
                                    <div class="col-4">
                                        <span style="text-align:center;" t-if="res_company.phone">
                                            <strong>Phone:</strong>
                                            <span t-field="res_company.phone"/>
                                        </span>

                                        <span style="text-align:center;" t-if="res_company.email">
                                            <strong>Email:</strong>
                                            <span t-field="res_company.email"/>
                                        </span>
                                        <span style="text-align:center;" t-if="res_company.email">
                                            <strong>Website:</strong>
                                            <span t-field="res_company.website"/>
                                        </span>
                                    </div>

                                    <div class="col-2">
                                        <span style="width:50%;text-align:left;">
                                            <img t-if="o.qrcode" t-att-src="image_data_uri(o.qrcode)"
                                                 style="height: 70px;" alt="QR Code"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="col-6" style="text-align:right;">
                                    <span style="text-align:left;">
                                        <strong>Page:</strong>
                                        <span class="page"/>
                                        of
                                        <span class="topage"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <record id="paperformat_medical_lab_report" model="report.paperformat">
            <field name="name">Analysis Report A4</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">40</field>
            <field name="margin_bottom">25</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">20</field>
            <field name="dpi">90</field>
        </record>

        <!--        <report-->
        <!--                id="medical_lab_analysis_report"-->
        <!--                model="lims.sample.main"-->
        <!--                report_type="qweb-pdf"-->
        <!--                string="Analysis Report"-->
        <!--                name="lims.analysis_report_document"-->
        <!--                file="lims.analysis_report"-->
        <!--                print_report_name="'Report - %s' % (object.partner_id.name or '',)"-->
        <!--                paperformat="lims.paperformat_medical_lab_report"-->
        <!--        />-->
        <record id="medical_lab_analysis_report" model="ir.actions.report">
            <field name="name">Analysis Report</field>
            <field name="model">lims.sample.main</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">lims.analysis_report_document</field>
            <field name="report_file">lims.analysis_report</field>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="lims.paperformat_medical_lab_report"/>
            <field name="print_report_name">'Report - %s' % (object.partner_id.name or '',)</field>
        </record>
    </data>
</odoo>