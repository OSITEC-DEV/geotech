<odoo>
    <data>

        <record id="ir_cron_auto_lock_samples" model="ir.cron">

            <field name="name">Daily Auto Lock Samples</field>

            <field name="model_id" ref="model_lims_sample_main"/>

            <field name="state">code</field>
            <field name="code">model._cron_auto_lock_samples()</field>

            <field name="interval_number">1</field>
            <field name="interval_type">days</field>

            <field name="nextcall"
                   eval="(DateTime.now() + relativedelta(days=1)).replace(hour=20, minute=59, second=0).strftime('%Y-%m-%d %H:%M:%S')"/>

            <field name="user_id" ref="base.user_root"/>

            <field name="active">True</field>

        </record>

    </data>
</odoo>