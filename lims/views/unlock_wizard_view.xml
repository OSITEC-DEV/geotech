<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
       <record id="view_lims_sample_unlock_wizard" model="ir.ui.view">
            <field name="name">lims.sample.unlock.wizard.form</field>
            <field name="model">lims.sample.unlock.wizard</field>
            <field name="arch" type="xml">
                <form string="Unlock Sample">
                    <group>
                        <field name="reason" placeholder="Enter unlock reason..."/>
                        <field name="user_id"/>
                    </group>

                    <footer>
                        <button string="Confirm"
                                type="object"
                                name="action_confirm_unlock"
                                class="btn-primary"/>

                        <button string="Cancel"
                                special="cancel"
                                class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
