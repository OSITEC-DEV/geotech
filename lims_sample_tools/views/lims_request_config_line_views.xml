<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="view_lims_request_config_line_tree" model="ir.ui.view">
        <field name="name">lims.request.config.line.tree</field>
        <field name="model">lims.request.config.line</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="main_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="frequency"/>
                <field name="department_id"/>
                <field name="to_subcontract"/>
                <field name="income_account_id" optional="hide"/>
                <field name="request_category" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_lims_request_config_line_form" model="ir.ui.view">
        <field name="name">lims.request.config.line.form</field>
        <field name="model">lims.request.config.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="main_id"/>
                            <field name="sample_line_id"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="frequency"/>
                        </group>
                        <group>
                            <field name="department_id"/>
                            <field name="to_subcontract"/>
                            <field name="income_account_id"/>
                            <field name="sale_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lims_request_config_line" model="ir.actions.act_window">
        <field name="name">Request Configuration Lines</field>
        <field name="res_model">lims.request.config.line</field>
        <field name="view_mode">list,form</field>
    </record>

    </data>
</odoo>
