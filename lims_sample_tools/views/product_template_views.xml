<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="product_template_form_view_inherit_sample_tools" model="ir.ui.view">
        <field name="name">product.template.form.inherit.sample.tools</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="lims.product_template_form_view_inherit2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_sample_type']" position="after">
                <field name="allowed_sample_type_ids" widget="many2many_tags"/>
            </xpath>
            <xpath expr="//group[@name='qa_report']" position="after">
                <group string="Subcontracting" invisible="isParameter != True">
                    <field name="is_subcontract"/>
                </group>
            </xpath>
        </field>
    </record>

    </data>
</odoo>
