<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="view_lims_sample_wizard_form" model="ir.ui.view">
        <field name="name">lims.sample.wizard.form</field>
        <field name="model">lims.sample.wizard</field>
        <field name="arch" type="xml">
            <form string="Edit Samples">
                <field name="main_id" invisible="1"/>
                <field name="sample_ids" widget="many2many_tags" readonly="1"/>
                <group>
                    <field name="note"/>
                    <field name="user_id"/>
                    <field name="sample_date"/>
                    <field name="receiving_date"/>
                </group>
                <footer>
                    <button name="action_apply" string="Apply" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    </data>
</odoo>
