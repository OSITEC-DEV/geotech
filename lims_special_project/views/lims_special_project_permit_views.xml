<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="view_lims_special_project_permit_tree" model="ir.ui.view">
        <field name="name">lims.special.project.permit.tree</field>
        <field name="model">lims.special.project.permit</field>
        <field name="arch" type="xml">
            <list string="QC Permits">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="project_id"/>
                <field name="work_location"/>
                <field name="date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_lims_special_project_permit_form" model="ir.ui.view">
        <field name="name">lims.special.project.permit.form</field>
        <field name="model">lims.special.project.permit</field>
        <field name="arch" type="xml">
            <form string="QC Permit">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight"
                            invisible="state != 'submitted'"/>
                    <button name="action_reject" string="Reject" type="object"
                            invisible="state != 'submitted'"/>
                    <button name="action_close" string="Close" type="object"
                            invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="station_count" widget="statinfo" string="Stations"/>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="project_id"/>
                            <field name="laboratory_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="work_location"/>
                            <field name="required_tests"/>
                            <field name="equipment_used"/>
                            <field name="environmental_conditions"/>
                        </group>
                    </group>
                    <group string="Approval" invisible="not approved_by">
                        <field name="approved_by" readonly="1"/>
                        <field name="approved_on" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Site Stations">
                            <field name="station_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="location"/>
                                    <field name="layer_count"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_lims_special_project_permit" model="ir.actions.act_window">
        <field name="name">QC Permits</field>
        <field name="res_model">lims.special.project.permit</field>
        <field name="view_mode">list,form</field>
    </record>

    </data>
</odoo>
