#. module: lims_result
#: model_terms:ir.ui.view,arch_db:lims_result.product_template_form_view_inherit3
msgid ""
"<i>\n"
"                                    It's highly recommended that you use only alphanumerical code for correspondences\n"
"                                    (without special characters)\n"
"                                    <br/>\n"
"                                    Example :\n"
"                                    <strong style=\"color:green;\">Sodium ==&gt; NA , Glucose ==&gt; Glu</strong>\n"
"                                    <br/>\n"
"                                    While typing the formula , use the parameter code with brackets ( don't put spaces )\n"
"                                    <br/>\n"
"                                    Use [age] , [weight] to take automatically the age and the weight of Patient\n"
"                                    <br/>\n"
"                                    <strong>Example of Osmolality Formula :</strong>\n"
"                                    <br/>\n"
"                                    <strong style=\"color:blue;\">2*[NA] + [Glu]/18 + [BUN]/2.8</strong>\n"
"                                </i>"
msgstr ""
"<i>\n"
"                                    يوصى بشدة باستخدام رمز أبجدي رقمي فقط للمراسلات\n"
"                                    (بدون أحخاص خاصة)\n"
"                                    <br/>\n"
"                                    مثال :\n"
"                                    <strong style=\"color:green;\">الصوديوم ==&gt; NA ، الجلوكوز ==&gt; Glu</strong>\n"
"                                    <br/>\n"
"                                    أثناء كتابة الصيغة، استخدم رمز المعلمة بين قوسين (لا تضع مسافات)\n"
"                                    <br/>\n"
"                                    استخدم [age] ، [weight] لأخذ عمر ووزن المريض تلقائيًا\n"
"                                    <br/>\n"
"                                    <strong>مثال على صيغة الأسمولالية:</strong>\n"
"                                    <br/>\n"
"                                    <strong style=\"color:blue;\">2*[NA] + [Glu]/18 + [BUN]/2.8</strong>\n"
"                                </i>"

