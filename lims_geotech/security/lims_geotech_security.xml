<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="module_category_lims_geotech" model="ir.module.category">
        <field name="description">Helps you handle geotechnical site, borehole, and test data.</field>
        <field name="name">Geotechnical</field>
        <field name="sequence">7</field>
    </record>

    <record id="group_lims_geotech_user" model="res.groups">
        <field name="name">Geotech Technician</field>
        <field name="category_id" ref="module_category_lims_geotech"/>
        <field name="implied_ids" eval="[(4, ref('lims.group_lims_sample'))]"/>
        <field name="comment">The user can register sites, boreholes, and enter test readings.</field>
    </record>

    <record id="group_lims_geotech_manager" model="res.groups">
        <field name="name">Geotech Manager</field>
        <field name="category_id" ref="module_category_lims_geotech"/>
        <field name="implied_ids" eval="[(4, ref('group_lims_geotech_user'))]"/>
        <field name="comment">The user validates geotechnical test results and manages configuration.</field>
    </record>

    </data>
</odoo>
