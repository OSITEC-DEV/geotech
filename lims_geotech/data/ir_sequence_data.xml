<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_lims_geotech_site" model="ir.sequence">
            <field name="name">Geotechnical Site</field>
            <field name="code">lims.geotech.site</field>
            <field name="prefix">GS-%(y)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_lims_geotech_borehole" model="ir.sequence">
            <field name="name">Geotechnical Borehole</field>
            <field name="code">lims.geotech.borehole</field>
            <field name="prefix">BH-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_lims_geotech_test_spt" model="ir.sequence">
            <field name="name">Geotechnical SPT Test</field>
            <field name="code">lims.geotech.test.spt</field>
            <field name="prefix">SPT-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
