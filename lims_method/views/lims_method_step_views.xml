<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="lims_method_step_view_form" model="ir.ui.view">
            <field name="name">lims.method.step.form</field>
            <field name="model">lims.method.step</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name='state' widget="statusbar"/>
                        <button name="do_validate" type="object" string="Validate" class="oe_highlight" invisible= "state not in ['draft']"/>
                        <button name="reset_draft" type="object" string="Reset Draft" invisible= "state not in ['validated']"/>
                    </header>
                    <div class="oe_title">
                        <h1>
                            <label for="name" class="oe_edit_only"/>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group string="Documentation">
                        <field name="attachment" widget="binary"/>
                        <field name="version"/>
                    </group>
                    <group string="Steps Details" col='4'>
                        <field name="sequence"/>
                        <field name="timeline" widget="float_time"/>
                        <field name="user_id"/>
                        <field name="need_approve"/>
                        <field name="default_equipment_id" help='The default equipment used in this step'/>
                    </group>
                </form>
            </field>
        </record>

    </data>
</odoo>