<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="module_category_lims_rig" model="ir.module.category">
        <field name="description">Helps you handle soil testing rig fleet and scheduling.</field>
        <field name="name">RIG Management</field>
        <field name="sequence">6</field>
    </record>

    <record id="group_lims_rig_user" model="res.groups">
        <field name="name">Rig User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">The user can view and schedule rigs.</field>
    </record>

    <record id="group_lims_rig_manager" model="res.groups">
        <field name="name">Rig Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_lims_rig_user'))]"/>
        <field name="comment">The user manages the rig fleet, maintenance, and scheduling approvals.</field>
    </record>

    </data>
</odoo>
