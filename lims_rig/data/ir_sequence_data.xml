<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_lims_rig" model="ir.sequence">
            <field name="name">Rig</field>
            <field name="code">lims.rig</field>
            <field name="prefix">RIG-</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_lims_rig_schedule" model="ir.sequence">
            <field name="name">Rig Schedule</field>
            <field name="code">lims.rig.schedule</field>
            <field name="prefix">RSCH-%(y)s%(month)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
